{
  "name": "aws-webrtc-poc",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "webpack serve --config webpack.renderer.cjs",
    "build:renderer": "webpack --config webpack.renderer.cjs",
    "build:main": "webpack --config webpack.main.cjs",
    "build:preload": "webpack --config webpack.preload.cjs",
    "build:electron": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dev:electron": "electronmon dist/main/main.js",
    "electron:dev": "concurrently -k \"npm run dev:renderer\" \"npm run build:main -- --watch\" \"npm run build:preload -- --watch\" \"wait-on tcp:5173 && npm run dev:electron\"",
    "start:backend": "tsx src/server.ts",
    "start:camera": "tsx src/simulator/camera-device.ts",
    "dev:all": "concurrently -k \"npm run start:backend\" \"npm run start:camera\" \"npm run electron:dev\""
  },
  "dependencies": {
    "@aws-sdk/client-iot": "^3.1019.0",
    "@aws-sdk/client-kinesis-video": "^3.1019.0",
    "@aws-sdk/client-kinesis-video-signaling": "^3.1019.0",
    "@aws-sdk/client-mediaconvert": "^3.1019.0",
    "@aws-sdk/client-medialive": "^3.1019.0",
    "@aws-sdk/client-mediapackage": "^3.1019.0",
    "@aws-sdk/client-mediapackagev2": "^3.1019.0",
    "@aws-sdk/client-mediastore": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@electron/remote": "^2.1.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "amazon-kinesis-video-streams-webrtc": "^2.6.1",
    "aws-iot-device-sdk-v2": "^1.25.1",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "electron": "^41.1.0",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "hls.js": "^1.6.15",
    "lucide-react": "^1.7.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.4",
    "html-webpack-plugin": "^5.6.6",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  }
}
